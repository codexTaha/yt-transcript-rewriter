# ============================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- AI Provider ---
# Provider: anthropic | gemini | openrouter
AI_PROVIDER=openrouter

# OpenRouter API Key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Best free model for long-context transcript rewriting.
# Full list of free models: https://openrouter.ai/models?max_price=0
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Anthropic (if switching to AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google Gemini (if switching to AI_PROVIDER=gemini)
GEMINI_API_KEY=

# Max tokens per AI rewrite chunk
AI_MAX_TOKENS=8192

# --- Transcript Extraction ---
# Optional: path to Netscape cookies.txt from your browser (most reliable)
YOUTUBE_COOKIES_FILE=

# Optional: Webshare rotating residential proxy (paid)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Optional: Generic proxy host:port
PROXY_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
