# ============================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- AI Provider ---
AI_PROVIDER=openrouter

# OpenRouter API Key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Default primary model (user can override per-job in the prompt modal)
# Full list of free models: https://openrouter.ai/models?max_price=0
AI_MODEL=deepseek/deepseek-r1-0528:free

# Fallback chain (automatic, no config needed):
#   1. deepseek/deepseek-r1-0528:free    (primary)
#   2. meta-llama/llama-3.3-70b-instruct:free  (fallback 1)
#   3. mistralai/mistral-7b-instruct:free      (fallback 2)

# Max tokens per AI rewrite chunk
AI_MAX_TOKENS=8192

# --- Transcript Extraction ---
YOUTUBE_COOKIES_FILE=
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
PROXY_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
