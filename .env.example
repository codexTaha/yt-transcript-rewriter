# ============================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- AI Provider ---
AI_PROVIDER=openrouter

# OpenRouter API Key — get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Default primary model (user can override per-job in the prompt modal)
# All IDs verified free on OpenRouter as of March 2026
# Full list: https://openrouter.ai/models?max_price=0
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Automatic fallback chain (no config needed):
#   1. meta-llama/llama-3.3-70b-instruct:free  (primary / default)
#   2. google/gemma-3-27b-it:free              (fallback 1)
#   3. mistralai/mistral-small-3.1-24b-instruct:free  (fallback 2)
#   4. meta-llama/llama-3.2-3b-instruct:free   (emergency fallback)

# Max tokens per AI rewrite chunk
AI_MAX_TOKENS=8192

# --- Transcript Extraction ---
YOUTUBE_COOKIES_FILE=
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
PROXY_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
