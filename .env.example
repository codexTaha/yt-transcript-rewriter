# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── YouTube Data API v3 ─────────────────────────────────────────────────────
# !! REQUIRED — without this, ALL playlist/channel/video discovery will fail !!
# Get yours: https://console.cloud.google.com/
#   1. Create a project
#   2. APIs & Services → Enable APIs → search "YouTube Data API v3" → Enable
#   3. APIs & Services → Credentials → Create API key
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ─── App URL ─────────────────────────────────────────────────────────────────
# !! REQUIRED — without this, the extract pump cannot fire self-calls and
# videos will never get transcribed (they stay in 'pending' forever) !!
# Local dev : http://localhost:3000
# Production: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Python / Transcript Auth ────────────────────────────────────────────────
# PYTHON_BIN: Explicit path to the Python executable that has youtube-transcript-api installed.
# If not set, the app auto-detects: project venv → system python3.
# Fedora / Linux example:
#   PYTHON_BIN=/home/taha/YT-Tools/yt-transcript-rewriter/venv/bin/python3
#   PYTHON_BIN=/home/taha/venv/bin/python3
PYTHON_BIN=

# YOUTUBE_COOKIES_FILE: Path to a Netscape-format cookies.txt exported from your browser.
# !! STRONGLY RECOMMENDED for local dev — prevents YouTube IP blocks !!
#
# AUTO-DETECT: If this is left empty, the app automatically checks these paths:
#   ~/cookies.txt
#   ~/YT-Tools/cookies.txt
#   ~/youtube_cookies.txt
#   <project-root>/cookies.txt
#
# How to export cookies.txt:
#   Chrome/Firefox extension: "Get cookies.txt LOCALLY" or "Cookie-Editor"
#   Make sure you are signed in to YouTube before exporting.
#
# Fedora example (already on your machine):
#   YOUTUBE_COOKIES_FILE=/home/taha/cookies.txt
YOUTUBE_COOKIES_FILE=

# Optional proxy auth (Webshare rotating residential — paid tier required)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Optional generic proxy (host:port, no protocol prefix)
PROXY_URL=
