# ============================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- AI Provider ---
# Provider: anthropic | gemini | openrouter
AI_PROVIDER=openrouter

# OpenRouter API Key (default provider — free models available)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Best free model for transcript rewriting (long context, high quality)
AI_MODEL=google/gemini-2.5-flash-preview:free

# Anthropic (if switching to AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini (if switching to AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here

# Max tokens for AI rewrite output per chunk
AI_MAX_TOKENS=8192

# --- Transcript Extraction ---
# Optional: path to Netscape cookies.txt exported from your browser
# Export while logged into youtube.com using "Get cookies.txt LOCALLY" extension
YOUTUBE_COOKIES_FILE=

# Optional: Webshare rotating residential proxy (paid)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Optional: Generic proxy host:port
PROXY_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
