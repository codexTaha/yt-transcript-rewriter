# ============================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER commit .env.local to git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- YouTube Data API v3 ---
# Get from: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- AI Provider ---
# Provider: anthropic | gemini
AI_PROVIDER=gemini

# Anthropic API Key (if using AI_PROVIDER=anthropic)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini API Key (if using AI_PROVIDER=gemini)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model name — configurable, never hardcoded in business logic
# Gemini 2.5 Flash — free tier: 20 RPD, 5 RPM, 250K TPM
AI_MODEL=gemini-2.5-flash

# Max tokens for AI rewrite output per chunk
AI_MAX_TOKENS=4096

# --- Transcript Extraction ---
# Optional: path to a Netscape cookies.txt exported from your browser
# (Chrome/Firefox extension: "Get cookies.txt LOCALLY")
# Export while logged into youtube.com, then set the absolute path here.
YOUTUBE_COOKIES_FILE=

# Optional: Webshare rotating residential proxy (paid tier)
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Optional: Generic proxy (host:port)
PROXY_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
